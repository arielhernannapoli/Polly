using Polly;

namespace Polly.Retry.Example.DelegatingHandler.Handlers
{
    public class PollyDelegatingHandler : System.Net.Http.DelegatingHandler
    {
        private readonly IAsyncPolicy<HttpResponseMessage> _policy;

        public PollyDelegatingHandler(IAsyncPolicy<HttpResponseMessage> policy)
        {
            _policy = policy;
        }

        protected override async Task<HttpResponseMessage> SendAsync(
            HttpRequestMessage request,
            CancellationToken cancellationToken)
        {
            var response = await _policy.ExecuteAsync(
                async (context) => await base.SendAsync(request, cancellationToken),
                new Context());

            return response;
        }
    }
}
